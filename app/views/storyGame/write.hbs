<h1>Write Your Part</h1>

<p class="story-meta"><strong>Turn {{add room.currentTurn 1}}</strong> of {{room.players.length}}</p>
<p class="story-meta">Story #{{storyIndex}}</p>
<p class="story-meta">Time Left: <span id="timer">{{timeLeft}}</span> seconds</p>

<form id="writeForm" onclick="playMusic({{room.settings.enableScotlandMode}})" action="/games/story/{{code}}/write"
    method="POST">
    <textarea class="story-textarea" name="content" rows="12" required>{{previousContent}}</textarea>
    <input type="hidden" name="code" value="{{code}}">
    <input type="hidden" name="turn" value="{{room.currentTurn}}">
    <input type="hidden" name="username" value="{{username}}">
    <br>
</form>

<p class="story-meta">Time Left: <span id="timer2">{{timeLeft}}</span> seconds</p>

<audio id="bagpipe-audio" preload="auto">
    <source src="/audio/bagpipes.mp3" type="audio/mpeg">
</audio>
<script>
    const scotlandMode = {{ room.settings.enableScotlandMode }};

    if (scotlandMode) {
        document.body.classList.add('scotland-mode');
    }


    function playMusic(musicEnabled) {
        if (musicEnabled) {
            const bagpipeAudio = document.getElementById('bagpipe-audio');
            bagpipeAudio.play();
        }
    }
</script>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const code = "{{code}}";
    const username = "{{username}}";
    socket.emit('join-room', code);
    const easyMDE = new EasyMDE({
        toolbar: ["bold", "italic", "|", "preview"],
        status: ["lines", "words"],
        spellChecker: false,
        renderingConfig: {
            sanitizerFunction: (renderedHTML) => {
                return DOMPurify.sanitize(renderedHTML, {
                    ALLOWED_TAGS: ['b', 'i', 'strong', 'em', 'p', 'br', 'ul', 'ol', 'li', 'h1', 'h2', 'h3', 'blockquote'],
                    ALLOWED_ATTR: []
                });
            }
        }
    });
    let time = {{ timeLeft }};
    const timerEl = document.getElementById('timer');
    const timerEl2 = document.getElementById('timer2');
    const form = document.getElementById('writeForm');

    const countdown = setInterval(() => {
        time--;
        timerEl.textContent = time;
        timerEl2.textContent = time;
        if (time <= 0) {
            clearInterval(countdown);
            form.submit(); // or lock input and wait for server redirect
        }
    }, 1000);

    socket.on("start-turn", ({ turn, endsIn }) => {
        window.location.href = `/games/story/${code}/write?turn=${turn}&username=${username}`;
    });

    socket.on("start-reading-phase", ({ turn, endsIn }) => {
        window.location.href = `/games/story/${code}/reading?username=${username}`;
    });

    socket.on("game-finished", () => {
        window.location.href = `/games/story/${code}/results`;
    });
</script>
